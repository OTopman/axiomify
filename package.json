{
  "name": "axiomify-workspace",
  "description": "Zero-compromise Node.js framework with Radix routing, Zod-native validation, and a modular plugin ecosystem for building high-performance, type-safe APIs.",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "maskify-ts": "^3.5.0"
  },
  "keywords": [
    "nodejs",
    "framework",
    "web-framework",
    "backend",
    "api",
    "http",
    "server",
    "fastify-alternative",
    "express-alternative",
    "nestjs-alternative",
    "high-performance",
    "radix-router",
    "routing",
    "zod",
    "validation",
    "type-safe",
    "typescript",
    "schema-first",
    "plugin-system",
    "microservices",
    "rest-api"
  ]
}
